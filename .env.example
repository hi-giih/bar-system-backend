# Copie este arquivo para ".env" e preencha com valores reais.
# O ".env" nunca deve ser commitado (ja esta no .gitignore).

# Chave secreta do Flask (sessoes, tokens). Gere uma aleatoria em producao.
SECRET_KEY=troque-por-uma-chave-aleatoria-segura

# String de conexao do banco. Em dev pode deixar em branco para usar SQLite local.
# Em producao, use a connection string do Supabase (Settings > Database > Connection string).
DATABASE_URL=

# "true" para ligar o modo debug do Flask (so em desenvolvimento local).
FLASK_DEBUG=true

# Dados do recebedor usados para gerar o codigo Pix (padrao Bacen/EMV).
PIX_KEY=
PIX_RECEIVER_NAME=
PIX_RECEIVER_CITY=

# Credenciais do unico usuario admin (login).
# ADMIN_PASSWORD_HASH e gerado localmente (nunca coloque a senha em texto puro aqui).
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Chave usada para assinar os tokens JWT. Se nao definida, reusa a SECRET_KEY.
# Recomendado gerar uma diferente da SECRET_KEY.
JWT_SECRET_KEY=

# Envio do relatorio semanal por email via API HTTP da Resend (resend.com).
# SMTP puro nao funciona em producao: o Render bloqueia conexoes SMTP de
# saida, entao o envio precisa ser sobre HTTPS.
# RESEND_API_KEY: gerada em resend.com > API Keys.
# RESEND_REMETENTE: "onboarding@resend.dev" funciona sem verificar dominio
# proprio (plano free); para um remetente com dominio proprio, verifique-o
# antes em resend.com > Domains.
RESEND_API_KEY=
RESEND_REMETENTE=onboarding@resend.dev
RELATORIO_EMAIL_DESTINATARIO=

# Segredo usado pelo workflow agendado do GitHub Actions para chamar
# POST /relatorios/comandas/enviar-email sem precisar de login (JWT).
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# O mesmo valor precisa estar cadastrado como secret no repositorio do
# GitHub (Settings > Secrets and variables > Actions) com o nome
# RELATORIO_CRON_SECRET.
RELATORIO_CRON_SECRET=
